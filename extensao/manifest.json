{
  "manifest_version": 3,
  "name": "Friganso ERP - Resumo Rápido",
  "version": "2.0.0",
  "description": "Lê o pedido do SPAmov para o Resumo e lança pedidos montados no app, direto no SPAmov.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "*://*.friganso.com.br/*",
        "*://spd1.friganso.com.br/*",
        "*://tkadachii.github.io/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
